# Docker Compose reads values from a root .env file.
# Copy this file to .env for local Docker development.

POSTGRES_USER=breach_user
POSTGRES_PASSWORD=breach_password
POSTGRES_DB=breach_analytics

# Inside Docker Compose, the PostgreSQL host is the service name: db.
DATABASE_URL=postgresql+psycopg://breach_user:breach_password@db:5432/breach_analytics
